<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!-- Strict: all checks enabled at default severity -->

    <!-- WrongRegion: de-rNE (Neo), es-rLA (Latin America), ru-rPH (Phonetic)
         are keyboard layout identifiers using locale qualifiers, not real
         language-region pairs. Cannot be renamed without breaking layouts. -->
    <issue id="WrongRegion" severity="ignore" />

    <!-- AGP 9.x and Kotlin 2.2.x are major version bumps requiring deliberate
         migration; suppress until the migration is planned. -->
    <issue id="AndroidGradlePluginVersion" severity="ignore" />
    <!-- GradleDependency: remaining upgrades require compileSdk 35+ or AGP 9+,
         which is blocked by the build-config constraint (compileSdk=34, AGP 8.5.2).
         Suppress until the compileSdk/AGP migration is planned. -->
    <issue id="GradleDependency" severity="ignore" />

    <!-- Overdraw: candidate_preview.xml and candidates.xml are legacy AOSP
         layout files whose backgrounds are functionally required for the
         candidate strip visual. Removing them would break the UI. -->
    <issue id="Overdraw" severity="ignore" />

    <!-- IconDuplicates: material_dark and material_black are distinct themes
         that happen to share similar icons by design. sym_keyboard_feedback_done
         and ic_subtype_keyboard serve different semantic roles even if the
         bitmaps are similar at mdpi. Deduplicating would require aliasing
         infrastructure not yet in place. -->
    <issue id="IconDuplicates" severity="ignore" />

    <!-- DiscouragedApi: Several legacy AOSP input method APIs (e.g.
         InputMethodManager.showInputMethodPicker) have no AndroidX replacement.
         The codebase relies on them intentionally as an IME service. -->
    <issue id="DiscouragedApi" severity="ignore" />

    <!-- QueryPermissionsNeeded: The app queries installed input methods via
         InputMethodManager, which is an IME-specific privileged operation that
         does not require a <queries> manifest element under the IME service
         calling convention. -->
    <issue id="QueryPermissionsNeeded" severity="ignore" />

    <!-- StaticFieldLeak: LatinIME.sInstance is a weak-reference-guarded static
         used exclusively for debug/test broadcast receivers. The leak risk is
         accepted and documented in LatinIME.kt. -->
    <issue id="StaticFieldLeak" severity="ignore" />

    <!-- ClickableViewAccessibility: Legacy AOSP CandidateView and keyboard
         surface use custom touch handling that predates AccessibilityDelegate.
         Refactoring is deferred to a dedicated accessibility pass. -->
    <issue id="ClickableViewAccessibility" severity="ignore" />

    <!-- GestureBackNavigation: The keyboard surface consumes back gestures by
         design (IME dismiss). Migrating to the predictive-back API requires
         changes to the IME lifecycle contract and is planned for a future
         release. -->
    <issue id="GestureBackNavigation" severity="ignore" />

    <!-- AppBundleLocaleChanges: The app ships locale-specific keyboard layout
         XML files (xml-*/kbd_*.xml) that must be present at install time.
         On-demand locale delivery via Play Asset Delivery is not compatible
         with this architecture without a full resource restructuring. -->
    <issue id="AppBundleLocaleChanges" severity="ignore" />

    <!-- LaunchActivityFromNotification: The notification action launches the
         settings Activity from an IME service notification, which requires
         FLAG_ACTIVITY_NEW_TASK. This is the correct pattern for IME services
         that cannot use normal activity back-stack navigation. -->
    <issue id="LaunchActivityFromNotification" severity="ignore" />

    <!-- IconDensities / IconDipSize: Legacy AOSP drawable assets were supplied
         at fixed density buckets (mdpi/hdpi/xhdpi/xxhdpi) without xxxhdpi or
         vector equivalents. Full icon regeneration is deferred to the design
         refresh milestone. -->
    <issue id="IconDensities" severity="ignore" />
    <issue id="IconDipSize" severity="ignore" />

    <!-- OldTargetApi: targetSdk=34 is intentional per build-config rules;
         bumping requires deliberate testing. -->
    <issue id="OldTargetApi" severity="ignore" />

    <!-- UnusedAttribute: enableOnBackInvokedCallback in debug manifest is
         forward-compat for API 33+ predictive back gesture. -->
    <issue id="UnusedAttribute" severity="ignore" />

    <!-- InflateParams: Legacy AOSP CandidateView and popup inflation use null
         parent by design (detached views attached to window manager). -->
    <issue id="InflateParams" severity="ignore" />

    <!-- IconDuplicatesConfig: Stone theme 9-patch drawables are intentionally
         identical across density buckets (fixed-size 9-patch artwork). -->
    <issue id="IconDuplicatesConfig" severity="ignore" />
</lint>
